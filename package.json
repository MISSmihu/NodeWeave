{
  "name": "nexus",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute nexus-db --local --file=api/migrations",
    "db:migrate:remote": "wrangler d1 execute nexus-db --remote --file=api/migrations"
  },
  "devDependencies": {
    "wrangler": "^3",
    "hono": "^4"
  }
}
